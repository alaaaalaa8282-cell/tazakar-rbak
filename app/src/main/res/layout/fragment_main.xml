<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">


    <ScrollView
        android:id="@+id/container_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

           <!-- الإهداء والصورة جنب بعض -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1A2E1A"
    android:gravity="center"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- الإهداء (النص) -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="إهداءً إلى روح والدي الحبيب\nمحمد عبد العظيم الطويل\nرحمه الله وأسكنه فسيح جناته"
        android:textColor="#FFD700"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"/>

    <!-- فاصل عمودي -->
    <View
        android:layout_width="1dp"
        android:layout_height="48dp"
        android:background="#FFD700"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>

    <!-- صورة الوالد والنص -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/father_photo"
            android:scaleType="centerCrop"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="محمد عبد العظيم طرفايه الطويل"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="رحمه الله وأسكنه فسيح جناته"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"/>

    
</LinearLayout>
            <!-- ✅ كارد التاريخ والرمضان -->
            <LinearLayout
                android:id="@+id/date_ramadan_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:background="@color/panel_background_color"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/text_gregorian_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/text_hijri_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FFD700"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/text_ramadan_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <LinearLayout
                    android:id="@+id/layout_suhoor_iftar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/text_suhoor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="الإمساك: --"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/text_iftar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="الإفطار: --"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="center" />

                </LinearLayout>

                <TextView
                    android:id="@+id/text_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/text_countdown_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_athan"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/athan"
                    android:text="@string/athan"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

               <Button
                    android:id="@+id/button_quran"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/quran"
                    android:text="@string/quranic_verses"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />
               

            </LinearLayout>


            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_morning_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/sun"
                    android:text="@string/morningThikr"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />
               
                <Button
                    android:id="@+id/button_night_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/moon"
                    android:text="@string/nightThikr"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                 

            </LinearLayout>

            <!-- Row 3 -->
             <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_my_athkar"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/my_athkar"
                    android:text="@string/my_athkar"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

               <Button
                    android:id="@+id/button_qibla"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/qibla"
                    android:text="@string/qibla"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/hisn_almuslim"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/hisn_almuslim"
                    android:text="@string/hisn_almuslim"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_settings"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/settings"
                    android:text="@string/Settings"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

              <!-- متتبع الصلاة -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <Button
        android:id="@+id/button_prayer_tracker"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="8dp"
        android:background="@drawable/card_bg"
        android:text="📿 متتبع الصلاة اليومي"
        android:textColor="@color/colorAccent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="10dp" />

</LinearLayout>

            <Button
                android:id="@+id/button_sadaqa"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:background="@drawable/card_bg"
                android:drawableTop="@drawable/share_button"
                android:text="@string/sadaqa"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="10dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
